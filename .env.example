# Shared
LOG_LEVEL=INFO
POLICY_MODE=cloud-ok-no-train
ALLOW_ADMIN_TOOLS=false

# MCP server
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000
# Reserved for a reverse proxy or future server-side HTTP guards.
MCP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
MCP_AUTH_TOKEN=
IDEMPOTENCY_TTL_S=600
OSC_REPLY_TIMEOUT_MS=1500
BESPOKE_CMD_HOST=127.0.0.1
BESPOKE_CMD_PORT=9001
REPLY_LISTEN_HOST=127.0.0.1
REPLY_LISTEN_PORT=9002
TELEMETRY_LISTEN_HOST=127.0.0.1
TELEMETRY_LISTEN_PORT=9010
BESPOKE_KNOWN_MODULES=transport,filter~cutoff,main~volume,snapshots

# Orchestrator
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8088
MCP_CLIENT_TRANSPORT=http
MCP_SERVER_URL=http://127.0.0.1:8000/mcp
MCP_SERVER_CMD=python -m mcp_bespoke_server.server
MCP_CLIENT_TIMEOUT_S=10
CONSENT_REQUIRED_FOR_RISKY=true
DEFAULT_PLANNER_PROVIDER=mock
DEFAULT_SUMMARIZER_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-sonnet-4-5
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-pro
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080/v1
LLAMA_CPP_MODEL=local-model
